<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Velocity Enterprises | Premium Scientific Distribution</title>
    <style>
        /* Premium Color Palette (Derived from Logo Gold and Black) */
        :root {
            --rich-black: #08090a;
            --charcoal: #1c1f21;
            --premium-gold: #c6a061; /* Derived from logo bronze/gold */
            --dark-bronze: #8e6d3c;   /* Derived from logo */
            --text-light: #e0e0e0;
            --text-muted: #a0a0a0;
        }

        body { font-family: 'Playfair Display', serif; background-color: var(--rich-black); color: var(--text-light); margin: 0; line-height: 1.8; -webkit-font-smoothing: antialiased; }
        h1, h2, h3 { font-family: 'Garamond', serif; font-weight: 300; text-transform: uppercase; letter-spacing: 2px; }

        header { background: var(--charcoal); padding: 1.5rem 8%; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 1000; border-bottom: 1px solid var(--dark-bronze); box-shadow: 0 4px 20px rgba(0,0,0,0.5); }
        .logo-container { display: flex; align-items: center; gap: 20px; }
        
        /* THIS LINE NOW POINTS TO YOUR LOCAL LOGO FILE */
        .logo-image { height: 60px; width: auto; } 

        .logo-text { font-size: 1.6rem; color: var(--premium-gold); font-weight: 700; letter-spacing: 4px; }

        nav a { color: var(--text-light); text-decoration: none; margin-left: 25px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1.5px; transition: color 0.3s ease; }
        nav a:hover { color: var(--premium-gold); }
        .distributor-tag { background: transparent; color: var(--premium-gold); padding: 6px 15px; border: 1px solid var(--premium-gold); border-radius: 20px; font-size: 0.75rem; text-transform: uppercase; font-weight: bold; }

        .hero { background: linear-gradient(rgba(8,9,10,0.92), rgba(8,9,10,0.92)), url('https://images.unsplash.com/photo-1579389083078-4e7018379f7e?auto=format&fit=crop&q=80&w=1600'); 
                background-size: cover; height: 550px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 0 15%; border-bottom: 2px solid var(--dark-bronze); }
        .hero h1 { font-size: 4rem; color: var(--premium-gold); margin-bottom: 15px; text-shadow: 0 2px 10px rgba(198,160,97,0.3); }
        .hero p { font-size: 1.4rem; max-width: 900px; color: var(--text-muted); }

        .brand-bar { background: var(--rich-black); padding: 30px; text-align: center; border-bottom: 1px solid var(--charcoal); }
        .brand-bar span { color: var(--text-muted); text-transform: uppercase; letter-spacing: 2px; margin-right: 20px; }
        .brand-name { font-size: 2rem; color: #ffebcc; font-weight: 900; letter-spacing: 4px; }

        .section { padding: 80px 10%; }
        .section-title { text-align: center; margin-bottom: 60px; position: relative; }
        .section-title h2 { font-size: 2.5rem; color: var(--text-light); }
        .section-title::after { content: ''; display: block; width: 100px; height: 2px; background: var(--premium-gold); margin: 15px auto 0; }

        .product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px; }
        .product-card { background: var(--charcoal); border: 1px solid var(--charcoal); padding: 35px; border-radius: 4px; transition: all 0.4s ease; position: relative; overflow: hidden; }
        .product-card:hover { border-color: var(--dark-bronze); transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.4); }
        .product-card h3 { color: var(--premium-gold); margin-top: 0; padding-bottom: 15px; border-bottom: 1px solid rgba(198,160,97,0.2); }
        .product-card ul { padding-left: 20px; font-size: 1rem; color: var(--text-muted); }

        .contact-container { background: var(--charcoal); color: var(--text-light); padding: 70px; border-radius: 4px; border: 1px solid var(--dark-bronze); display: flex; flex-wrap: wrap; gap: 50px; box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
        .contact-info { flex: 1.2; min-width: 350px; }
        .contact-form { flex: 1; min-width: 350px; background: rgba(255,255,255,0.03); padding: 40px; border-radius: 2px; }
        .contact-link { color: var(--premium-gold); text-decoration: none; font-weight: bold; transition: opacity 0.3s; }
        .contact-link:hover { opacity: 0.8; }

        .contact-form input, .contact-form textarea { width: 100%; padding: 15px; margin: 12px 0; border: 1px solid var(--charcoal); border-radius: 2px; box-sizing: border-box; background: var(--rich-black); color: var(--text-light); }
        .contact-form input:focus, .contact-form textarea:focus { border-color: var(--premium-gold); outline: none; }
        .contact-form button { width: 100%; background: var(--premium-gold); color: var(--rich-black); border: none; padding: 18px; font-weight: bold; text-transform: uppercase; letter-spacing: 2px; cursor: pointer; border-radius: 2px; transition: background 0.3s; }
        .contact-form button:hover { background: #e0bb7d; }

        footer { text-align: center; padding: 40px; background: var(--rich-black); color: var(--text-muted); font-size: 0.9rem; border-top: 1px solid var(--charcoal); }
    </style>
</head>
